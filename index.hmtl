<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skills · MCP · OpenSpec — Guia Completo</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=IBM+Plex+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
/* ── LIGHT MODE (default) ── */
:root {
  --ink: #0f0f0f;
  --paper: #f5f3ef;
  --paper2: #edeae3;
  --rule: #d8d3c8;
  --muted: #6b6560;
  --code-bg: #161620;
  --red: #7c3aed;
  --blue: #7c3aed;
  --mono: 'IBM Plex Mono', monospace;
  --serif: 'Playfair Display', serif;
  --sans: 'Outfit', sans-serif;
  /* dark-section surfaces (hero-l, def, mcp-flow, qbox, footer) */
  --dark-surf: #0f0f0f;
  --dark-surf2: #161620;
  --dark-text: #fff;
  --dark-muted: #6a6a80;
  --dark-sub: #4a4a5a;
  --dark-rule: rgba(255,255,255,.08);
  --dark-border: rgba(255,255,255,.1);
  --dark-hover: rgba(255,255,255,.07);
  --dark-body: #c8c8c0;
}
 
/* ── DARK MODE ── */
[data-theme="dark"] {
  --ink: #e8e5df;
  --paper: #111014;
  --paper2: #18161c;
  --rule: #2a2635;
  --muted: #8a8290;
  --code-bg: #0d0c12;
  /* dark-section surfaces stay almost same but slightly lighter */
  --dark-surf: #1c1a22;
  --dark-surf2: #0d0c12;
  --dark-text: #f0eee8;
  --dark-muted: #7a7888;
  --dark-sub: #4e4c5a;
  --dark-rule: rgba(255,255,255,.06);
  --dark-border: rgba(255,255,255,.12);
  --dark-hover: rgba(255,255,255,.05);
  --dark-body: #b0aead;
}
 
/* smooth theme transition */
body, body * { transition: background-color .3s ease, border-color .3s ease, color .3s ease; }
 
html { scroll-behavior: smooth; }
body { background: var(--paper); color: var(--ink); font-family: var(--sans); font-weight: 400; line-height: 1.75; font-size: 17px; }
 
/* ── THEME TOGGLE BUTTON ── */
.theme-toggle {
  display: flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
  border-radius: 20px; padding: 5px 14px 5px 10px;
  cursor: pointer; transition: background .2s, border-color .2s;
  flex-shrink: 0;
}
.theme-toggle:hover { background: rgba(255,255,255,.12); border-color: var(--red); }
.theme-toggle-track {
  width: 28px; height: 16px; border-radius: 8px;
  background: rgba(255,255,255,.15); position: relative;
  transition: background .3s;
}
.theme-toggle-thumb {
  width: 12px; height: 12px; border-radius: 50%;
  background: #fff; position: absolute; top: 2px; left: 2px;
  transition: transform .3s, background .3s;
  box-shadow: 0 1px 3px rgba(0,0,0,.3);
}
[data-theme="dark"] .theme-toggle-track { background: var(--red); }
[data-theme="dark"] .theme-toggle-thumb { transform: translateX(12px); }
.theme-toggle-label { font-family: var(--mono); font-size: 10px; color: #888; letter-spacing: .05em; user-select: none; }
[data-theme="dark"] .theme-toggle-label { color: #aaa; }
 
/* TOPBAR */
.topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--dark-surf); display: flex; align-items: center; justify-content: space-between; padding: 0 48px; height: 54px; }
.tb-brand { font-family: var(--mono); font-size: 12px; font-weight: 500; color: var(--dark-text); letter-spacing: .06em; }
.tb-brand span { color: var(--red); }
.tb-nav { display: flex; gap: 2px; }
.tb-nav a { font-family: var(--mono); font-size: 11px; color: #777; text-decoration: none; padding: 5px 12px; border-radius: 3px; transition: color .2s, background .2s; cursor: pointer; letter-spacing: .04em; }
.tb-nav a:hover, .tb-nav a.on { color: var(--dark-text); background: var(--dark-hover); }
#pbar { position: fixed; top: 54px; left: 0; height: 2px; background: var(--red); z-index: 101; transition: width .1s linear; width: 0; }
 
/* HERO */
.hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; padding-top: 54px; }
.hero-l { background: var(--dark-surf); padding: 80px 64px; display: flex; flex-direction: column; justify-content: center; }
.hero-eye { font-family: var(--mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--red); margin-bottom: 32px; }
.hero-h { font-family: var(--serif); font-size: clamp(48px, 5vw, 72px); font-weight: 900; line-height: 1; color: var(--dark-text); letter-spacing: -1px; margin-bottom: 28px; }
.hero-h em { color: var(--red); font-style: normal; }
.hero-p { color: var(--dark-muted); font-size: 16px; line-height: 1.8; max-width: 400px; margin-bottom: 48px; }
.hero-btns { display: flex; gap: 10px; flex-wrap: wrap; }
.hero-btn { border: 1px solid var(--dark-border); border-radius: 3px; padding: 8px 18px; font-family: var(--mono); font-size: 11px; color: #888; cursor: pointer; transition: all .2s; letter-spacing: .05em; }
.hero-btn:hover { border-color: var(--red); color: var(--dark-text); }
.hero-r { background: var(--paper2); padding: 80px 56px; display: flex; flex-direction: column; justify-content: center; border-left: 1px solid var(--rule); }
.idx-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); margin-bottom: 28px; }
.idx-item { display: flex; align-items: baseline; gap: 20px; padding: 18px 0; border-bottom: 1px solid var(--rule); cursor: pointer; transition: all .2s; }
.idx-item:last-child { border-bottom: none; }
.idx-item:hover .idx-n, .idx-item:hover .idx-title { color: var(--red); }
.idx-n { font-family: var(--mono); font-size: 11px; color: var(--rule); min-width: 28px; transition: color .2s; }
.idx-title { font-family: var(--serif); font-size: 20px; font-weight: 700; flex: 1; transition: color .2s; }
.idx-sub { font-size: 13px; color: var(--muted); }
 
/* SECTIONS */
section { scroll-margin-top: 54px; }
.sw { max-width: 860px; margin: 0 auto; padding: 96px 40px; }
.sw + .sw { border-top: 1px solid var(--rule); }
.s-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--red); margin-bottom: 18px; }
.s-title { font-family: var(--serif); font-size: clamp(34px, 4vw, 54px); font-weight: 900; line-height: 1.05; letter-spacing: -.5px; margin-bottom: 22px; }
.s-lead { font-size: 19px; font-weight: 300; color: var(--muted); line-height: 1.75; max-width: 660px; margin-bottom: 56px; border-left: 3px solid var(--red); padding-left: 22px; }
 
/* DEF BOX */
.def { background: var(--dark-surf); color: var(--dark-body); border-radius: 5px; padding: 36px 44px; margin-bottom: 44px; }
.def-lbl { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
.def p { font-size: 17px; line-height: 1.8; }
.def strong { color: var(--dark-text); }
code { font-family: var(--mono); font-size: 13px; background: rgba(255,255,255,.08); padding: 1px 6px; border-radius: 3px; color: #f1fa8c; }
 
/* SKILL ROWS */
.skill-list { display: flex; flex-direction: column; }
.sk { display: grid; grid-template-columns: 44px 190px 1fr 120px; align-items: start; gap: 28px; padding: 28px 0; border-bottom: 1px solid var(--rule); }
.sk:last-child { border-bottom: none; }
.sk:hover { background: rgba(0,0,0,.015); }
.sk-n { font-family: var(--mono); font-size: 11px; color: var(--rule); padding-top: 2px; }
.sk-name h3 { font-family: var(--serif); font-size: 19px; font-weight: 700; margin-bottom: 5px; }
.sk-file { font-family: var(--mono); font-size: 11px; color: var(--muted); }
.sk-body { font-size: 15px; color: var(--muted); line-height: 1.7; }
.sk-badge { font-family: var(--mono); font-size: 10px; background: var(--paper2); border: 1px solid var(--rule); border-radius: 3px; padding: 4px 10px; color: var(--muted); white-space: nowrap; margin-top: 2px; }
 
/* ANALOGY */
.analogy { background: var(--paper2); border: 1px solid var(--rule); border-radius: 5px; padding: 36px 44px; margin-top: 44px; }
.analogy h4 { font-family: var(--serif); font-size: 20px; font-weight: 700; margin-bottom: 12px; }
.analogy p { color: var(--muted); line-height: 1.8; font-size: 15px; }
.analogy strong { color: var(--ink); }
 
/* MCP FLOW */
.mcp-flow { background: var(--dark-surf); border-radius: 5px; padding: 56px 40px; margin-bottom: 44px; }
.mcp-nodes { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0; }
.mcp-node { text-align: center; min-width: 130px; }
.mcp-box { display: inline-flex; flex-direction: column; align-items: center; background: var(--dark-rule); border: 1px solid var(--dark-border); border-radius: 5px; padding: 18px 22px; transition: border-color .3s; }
.mcp-box:hover { border-color: var(--red); }
.mcp-box.center { border-color: rgba(124,58,237,.45); background: rgba(124,58,237,.07); }
.mcp-lbl { font-family: var(--mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
.mcp-name { font-size: 14px; font-weight: 600; color: var(--dark-text); }
.mcp-sub { font-size: 11px; color: var(--dark-sub); margin-top: 3px; }
.mcp-conn { flex: 1; min-width: 50px; max-width: 90px; display: flex; flex-direction: column; align-items: center; gap: 5px; }
.mcp-line { width: 100%; height: 1px; background: linear-gradient(90deg, var(--dark-rule), rgba(124,58,237,.35), var(--dark-rule)); position: relative; }
.mcp-line::after { content: '›'; position: absolute; right: -5px; top: -9px; color: var(--red); font-size: 13px; }
.mcp-clbl { font-family: var(--mono); font-size: 9px; color: var(--dark-sub); }
.mcp-caption { text-align: center; margin-top: 36px; font-family: var(--mono); font-size: 11px; color: var(--dark-sub); line-height: 1.7; }
 
/* FEATURE TABLE */
.ftable { display: flex; flex-direction: column; margin-top: 44px; }
.frow { display: grid; grid-template-columns: 220px 1fr; gap: 44px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: start; }
.frow:last-child { border-bottom: 1px solid var(--rule); }
.flabel { font-size: 15px; font-weight: 600; }
.flabel small { display: block; font-family: var(--mono); font-size: 10px; color: var(--muted); font-weight: 400; margin-top: 4px; letter-spacing: .03em; }
.ftext { font-size: 15px; color: var(--muted); line-height: 1.8; }
 
/* STEPS */
.steps { display: flex; flex-direction: column; margin-top: 44px; }
.step { display: grid; grid-template-columns: 60px 1fr; gap: 28px; padding: 36px 0; border-top: 1px solid var(--rule); align-items: start; }
.step:last-child { border-bottom: 1px solid var(--rule); }
.step-n { width: 44px; height: 44px; background: var(--dark-surf); color: var(--dark-text); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 13px; flex-shrink: 0; transition: background .2s; }
.step:hover .step-n { background: var(--red); }
.step-c h3 { font-family: var(--serif); font-size: 21px; font-weight: 700; margin-bottom: 10px; }
.step-c p { font-size: 15px; color: var(--muted); line-height: 1.8; }
.step-note { display: inline-block; margin-top: 12px; font-family: var(--mono); font-size: 10px; color: var(--muted); background: var(--paper2); border: 1px solid var(--rule); border-radius: 3px; padding: 4px 12px; }
 
/* TOOLS TABLE */
.ttable { width: 100%; border-collapse: collapse; margin: 36px 0; font-size: 15px; }
.ttable th { font-family: var(--mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); text-align: left; padding: 10px 14px; border-bottom: 2px solid var(--rule); }
.ttable td { padding: 14px 14px; border-bottom: 1px solid var(--rule); vertical-align: top; }
.ttable tr:hover td { background: rgba(0,0,0,.02); }
.tname { font-weight: 600; }
.ttype { font-family: var(--mono); font-size: 11px; color: var(--muted); }
 
/* OPENSPEC */
.os-intro { background: var(--dark-surf); color: var(--dark-body); border-radius: 5px; padding: 44px; margin-bottom: 44px; }
.os-intro h3 { font-family: var(--serif); font-size: 26px; font-weight: 700; color: var(--dark-text); margin-bottom: 14px; }
.os-intro p { color: var(--dark-muted); line-height: 1.8; font-size: 16px; }
.os-intro a { color: var(--red); text-decoration: none; }
.os-intro a:hover { text-decoration: underline; }
.codeblock { background: var(--code-bg); border-radius: 5px; padding: 28px 32px; margin: 20px 0; }
.cblbl { font-family: var(--mono); font-size: 10px; letter-spacing: .15em; text-transform: uppercase; color: #44445a; margin-bottom: 14px; }
.codeblock pre { font-family: var(--mono); font-size: 13px; line-height: 1.85; color: #a0b8d0; white-space: pre-wrap; word-break: break-all; }
.ck { color: #8be9fd; } .cs { color: #f1fa8c; } .cc { color: #44445a; font-style: italic; } .cp { color: #666; }
.os-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 36px 0; }
.os-card { background: var(--paper2); border: 1px solid var(--rule); border-radius: 5px; padding: 24px 28px; }
.os-card h4 { font-size: 15px; font-weight: 600; margin-bottom: 10px; }
.os-card p { font-size: 14px; color: var(--muted); line-height: 1.7; }
.method { display: inline-block; font-family: var(--mono); font-size: 10px; padding: 2px 7px; border-radius: 2px; margin: 2px 4px 2px 0; font-weight: 600; }
.mget { background: rgba(124,58,237,.1); color: #7c3aed; }
.mpost { background: rgba(22,163,74,.09); color: #16a34a; }
.mput { background: rgba(124,58,237,.08); color: #a78bfa; }
.mdel { background: rgba(220,38,38,.09); color: #dc2626; }
 
/* QUIZ */
.qbox { background: var(--dark-surf); border-radius: 5px; padding: 56px; }
.qtrack { display: flex; gap: 6px; margin-bottom: 44px; }
.qseg { flex: 1; height: 2px; background: var(--dark-rule); border-radius: 2px; transition: background .4s; }
.qseg.done { background: var(--red); }
.qseg.cur { background: rgba(124,58,237,.35); }
.qq { font-family: var(--serif); font-size: clamp(18px, 2.5vw, 26px); font-weight: 700; color: var(--dark-text); line-height: 1.35; margin-bottom: 32px; }
.qopts { display: flex; flex-direction: column; gap: 9px; max-width: 580px; }
.qopt { background: var(--dark-rule); border: 1px solid var(--dark-border); border-radius: 4px; padding: 14px 22px; color: #888; font-size: 15px; font-family: var(--sans); cursor: pointer; text-align: left; transition: all .2s; display: flex; align-items: center; gap: 14px; }
.qopt:hover { border-color: rgba(255,255,255,.25); color: #ccc; }
.qopt .ql { font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,.2); min-width: 18px; }
.qopt.ok { border-color: #16a34a; background: rgba(22,163,74,.07); color: #4ade80; }
.qopt.ok .ql { color: #4ade80; }
.qopt.err { border-color: #dc2626; background: rgba(220,38,38,.07); color: #f87171; }
.qopt.err .ql { color: #f87171; }
.qfb { margin-top: 24px; font-size: 14px; color: #505065; line-height: 1.75; min-height: 48px; transition: color .3s; }
.qfb.show { color: #8888a0; }
.qnext { margin-top: 28px; background: var(--red); color: #fff; border: none; border-radius: 4px; padding: 12px 28px; font-family: var(--sans); font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity .2s; display: none; letter-spacing: .02em; }
.qnext:hover { opacity: .88; }
 
/* FOOTER */
footer { background: var(--dark-surf); color: #444; padding: 52px 48px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; }
.ft-brand { font-family: var(--mono); font-size: 12px; color: #666; }
.ft-brand span { color: var(--red); }
footer p { font-size: 12px; font-family: var(--mono); }
 
/* RESPONSIVE */
@media (max-width: 880px) {
  .hero { grid-template-columns: 1fr; }
  .hero-r { display: none; }
  .hero-l { padding: 64px 32px; }
  .topbar { padding: 0 24px; }
  .sw { padding: 72px 24px; }
  .sk { grid-template-columns: 40px 1fr; }
  .sk-badge { display: none; }
  .frow { grid-template-columns: 1fr; gap: 10px; }
  .step { grid-template-columns: 48px 1fr; }
  .mcp-nodes { flex-direction: column; gap: 12px; }
  .mcp-conn { transform: rotate(90deg); width: 40px; }
  .os-cols { grid-template-columns: 1fr; }
  .qbox { padding: 36px 24px; }
  footer { padding: 36px 24px; }
}
@media (max-width: 600px) {
  .tb-nav { display: none; }
  .sk { grid-template-columns: 1fr; }
  .sk-n { display: none; }
}
 
/* REVEAL */
.reveal { opacity: 0; transform: translateY(18px); transition: opacity .65s ease, transform .65s ease; }
.reveal.in { opacity: 1; transform: translateY(0); }
</style>
</head>
<body>
 
<div id="pbar"></div>
 
<nav class="topbar">
  <div class="tb-brand">GUIA <span>·</span> Skills · MCP · OpenSpec</div>
  <div class="tb-nav">
    <a onclick="goTo('skills')" id="n-skills">Skills</a>
    <a onclick="goTo('mcp')" id="n-mcp">MCP</a>
    <a onclick="goTo('connectivity')" id="n-conn">Conectividade</a>
    <a onclick="goTo('openspec')" id="n-openspec">OpenSpec</a>
    <a onclick="goTo('quiz')" id="n-quiz">Quiz</a>
  </div>
  <div class="theme-toggle" onclick="toggleTheme()" title="Alternar tema">
    <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
    <span class="theme-toggle-label" id="theme-lbl">LIGHT</span>
  </div>
</nav>
 
<div class="hero">
  <div class="hero-l">
    <div class="hero-eye">Guia de Produtividade — 2025</div>
    <h1 class="hero-h">Skills,<br>MCP<br>&amp; <em>OpenSpec</em></h1>
    <p class="hero-p">As três tecnologias que definem como trabalhar com IA de forma profissional — do contexto especializado às conexões em tempo real e às especificações de API.</p>
    <div class="hero-btns">
      <div class="hero-btn" onclick="goTo('skills')">01 · Skills</div>
      <div class="hero-btn" onclick="goTo('mcp')">02 · MCP</div>
      <div class="hero-btn" onclick="goTo('connectivity')">03 · Conectividade</div>
      <div class="hero-btn" onclick="goTo('openspec')">04 · OpenSpec</div>
    </div>
  </div>
  <div class="hero-r">
    <div class="idx-lbl">Índice</div>
    <div class="idx-item" onclick="goTo('skills')"><span class="idx-n">01</span><div><div class="idx-title">Skills</div><div class="idx-sub">Capacidades especializadas</div></div></div>
    <div class="idx-item" onclick="goTo('mcp')"><span class="idx-n">02</span><div><div class="idx-title">MCP</div><div class="idx-sub">Model Context Protocol</div></div></div>
    <div class="idx-item" onclick="goTo('connectivity')"><span class="idx-n">03</span><div><div class="idx-title">Conectividade</div><div class="idx-sub">Montando seu fluxo</div></div></div>
    <div class="idx-item" onclick="goTo('openspec')"><span class="idx-n">04</span><div><div class="idx-title">OpenSpec</div><div class="idx-sub">APIs com OpenAPI</div></div></div>
    <div class="idx-item" onclick="goTo('quiz')"><span class="idx-n">05</span><div><div class="idx-title">Quiz</div><div class="idx-sub">Teste seu conhecimento</div></div></div>
  </div>
</div>
 
<!-- SKILLS -->
<section id="skills">
<div class="sw reveal">
  <div class="s-lbl">01 — Skills</div>
  <h2 class="s-title">O que são Skills?</h2>
  <p class="s-lead">Skills são instruções especializadas entregues ao Claude antes de uma tarefa. Funcionam como um manual técnico que orienta o modelo a executar um trabalho específico com qualidade consistente e profissional.</p>
 
  <div class="def">
    <div class="def-lbl">Definição</div>
    <p>Uma Skill é um <strong>arquivo de instruções estruturado</strong> disponível no ambiente do Claude. Quando você pede para criar um documento Word, o sistema carrega automaticamente a Skill <code>docx/SKILL.md</code> antes de executar — garantindo que o resultado siga padrões profissionais, não improvisados.</p>
  </div>
 
  <div class="skill-list">
    <div class="sk">
      <div class="sk-n">01</div>
      <div class="sk-name"><h3>Documentos Word</h3><div class="sk-file">docx/SKILL.md</div></div>
      <div class="sk-body">Instrui o Claude a criar arquivos .docx com formatação profissional — sumário, cabeçalhos hierárquicos, numeração de páginas, tabelas e estilos consistentes. Elimina o resultado genérico de texto simples sem estrutura.</div>
      <div class="sk-badge">.docx · .pdf</div>
    </div>
    <div class="sk">
      <div class="sk-n">02</div>
      <div class="sk-name"><h3>Apresentações</h3><div class="sk-file">pptx/SKILL.md</div></div>
      <div class="sk-body">Permite criar slides .pptx com layouts visuais corretos, hierarquia de informação, notas de apresentador e fluxo narrativo. O arquivo abre diretamente no PowerPoint com estrutura real.</div>
      <div class="sk-badge">.pptx</div>
    </div>
    <div class="sk">
      <div class="sk-n">03</div>
      <div class="sk-name"><h3>Planilhas</h3><div class="sk-file">xlsx/SKILL.md</div></div>
      <div class="sk-body">Orienta a criação de arquivos Excel com fórmulas reais, formatação condicional, validação de dados e estrutura de tabelas. O arquivo funciona imediatamente sem erros de compatibilidade.</div>
      <div class="sk-badge">.xlsx · .csv</div>
    </div>
    <div class="sk">
      <div class="sk-n">04</div>
      <div class="sk-name"><h3>Design Frontend</h3><div class="sk-file">frontend-design/SKILL.md</div></div>
      <div class="sk-body">Define critérios de qualidade visual para interfaces web — tipografia, paletas, layout e composição. Evita o resultado genérico de IA e garante código com identidade visual real e intencional.</div>
      <div class="sk-badge">HTML · CSS · React</div>
    </div>
    <div class="sk">
      <div class="sk-n">05</div>
      <div class="sk-name"><h3>Leitura de Arquivos</h3><div class="sk-file">file-reading/SKILL.md</div></div>
      <div class="sk-body">Um roteador de estratégia: define qual ferramenta usar para cada tipo de arquivo (PDF, Word, imagem, CSV) e como extrair o conteúdo correto sem desperdício de processamento.</div>
      <div class="sk-badge">PDF · DOCX · CSV</div>
    </div>
    <div class="sk">
      <div class="sk-n">06</div>
      <div class="sk-name"><h3>Skills Personalizadas</h3><div class="sk-file">skill-creator/SKILL.md</div></div>
      <div class="sk-body">Você pode criar suas próprias Skills — templates da empresa, checklists de revisão, padrões de código do time. Uma Skill é um arquivo de texto simples com instruções bem estruturadas.</div>
      <div class="sk-badge">Customizável</div>
    </div>
  </div>
 
  <div class="analogy">
    <h4>A analogia do cirurgião</h4>
    <p>Um cirurgião experiente sabe operar sem manual. Mas antes de um procedimento complexo, ele consulta o protocolo específico — instrumentos, sequência de passos, pontos críticos. Isso não o torna menos habilidoso; torna o resultado <strong>mais previsível e seguro</strong>. Skills funcionam assim: o Claude já é capaz, mas a Skill garante que ele siga o protocolo correto para cada tipo de tarefa.</p>
  </div>
</div>
</section>
 
<!-- MCP -->
<section id="mcp" style="background:var(--paper2)">
<div class="sw reveal">
  <div class="s-lbl">02 — MCP</div>
  <h2 class="s-title">Model Context Protocol</h2>
  <p class="s-lead">MCP é o protocolo aberto que permite ao Claude se conectar a ferramentas externas e agir no mundo real — não apenas responder, mas executar tarefas em outros sistemas.</p>
 
  <div class="mcp-flow">
    <div class="mcp-nodes">
      <div class="mcp-node">
        <div class="mcp-box">
          <div class="mcp-lbl">Usuário</div>
          <div class="mcp-name">Você</div>
          <div class="mcp-sub">dá a instrução</div>
        </div>
      </div>
      <div class="mcp-conn">
        <div class="mcp-line"></div>
        <div class="mcp-clbl">linguagem natural</div>
      </div>
      <div class="mcp-node">
        <div class="mcp-box center">
          <div class="mcp-lbl">Núcleo</div>
          <div class="mcp-name">Claude + MCP</div>
          <div class="mcp-sub">interpreta e roteia</div>
        </div>
      </div>
      <div class="mcp-conn">
        <div class="mcp-line"></div>
        <div class="mcp-clbl">chamadas de API</div>
      </div>
      <div class="mcp-node">
        <div class="mcp-box">
          <div class="mcp-lbl">Serviços</div>
          <div class="mcp-name">Ferramentas</div>
          <div class="mcp-sub">Slack · Notion · Gmail</div>
        </div>
      </div>
    </div>
    <div class="mcp-caption">
      Sem MCP, o Claude processa texto e devolve texto.<br>
      Com MCP, ele lê seus dados reais, age nos seus sistemas e traz resultados concretos.
    </div>
  </div>
 
  <div class="ftable">
    <div class="frow">
      <div class="flabel">Protocolo Aberto<small>Qualquer serviço pode implementar</small></div>
      <div class="ftext">MCP não é propriedade da Anthropic — é um padrão público. Qualquer empresa pode criar um servidor MCP para o seu produto. O ecossistema cresce de forma independente, como aconteceu com o HTTP.</div>
    </div>
    <div class="frow">
      <div class="flabel">Contexto em Tempo Real<small>Dados ao vivo, não estáticos</small></div>
      <div class="ftext">Com MCP, o Claude acessa seus emails de hoje, suas tarefas abertas agora, os dados do CRM desta semana. Não depende de contexto copiado manualmente — a conexão é direta e atualizada.</div>
    </div>
    <div class="frow">
      <div class="flabel">Confirmação Explícita<small>Controle sempre com você</small></div>
      <div class="ftext">Nenhuma ação sensível acontece sem sua confirmação. O Claude descreve o que vai fazer, mostra os detalhes e aguarda aprovação. O protocolo é projetado para manter o humano no controle.</div>
    </div>
    <div class="frow">
      <div class="flabel">Ações Compostas<small>Múltiplos sistemas, um comando</small></div>
      <div class="ftext">Uma instrução pode acionar vários servidores MCP em sequência. Três sistemas, uma frase, zero copiar e colar — o fluxo completo acontece numa única conversa.</div>
    </div>
  </div>
</div>
</section>
 
<!-- CONNECTIVITY -->
<section id="connectivity">
<div class="sw reveal">
  <div class="s-lbl">03 — Conectividade</div>
  <h2 class="s-title">Como montar seu fluxo de trabalho</h2>
  <p class="s-lead">Conectar Skills e MCP não exige configuração técnica complexa. Siga esta sequência para ter um ambiente de trabalho eficiente em menos de uma hora.</p>
 
  <div class="steps">
    <div class="step">
      <div class="step-n">01</div>
      <div class="step-c">
        <h3>Mapeie suas tarefas repetitivas</h3>
        <p>Liste o que você faz toda semana no piloto automático — criar relatórios, responder emails padrão, atualizar planilhas, postar atualizações em canais. Essas são as tarefas com maior retorno de automação.</p>
        <span class="step-note">Exercício: anote 5 tarefas que você repetiria amanhã</span>
      </div>
    </div>
    <div class="step">
      <div class="step-n">02</div>
      <div class="step-c">
        <h3>Ative os conectores MCP no Claude.ai</h3>
        <p>Acesse Configurações → Conectores. Você verá a lista de servidores MCP disponíveis. Ative apenas os serviços que você usa diariamente — começar com poucos e expandir progressivamente é mais eficaz.</p>
        <span class="step-note">claude.ai → Configurações → Conectores</span>
      </div>
    </div>
    <div class="step">
      <div class="step-n">03</div>
      <div class="step-c">
        <h3>As Skills trabalham automaticamente</h3>
        <p>Você não precisa especificar qual Skill usar. Ao pedir um documento Word, o sistema seleciona a Skill correta. Ao pedir uma planilha, a Skill de xlsx é carregada. Concentre-se na instrução, não na configuração.</p>
        <span class="step-note">Seleção automática por contexto, sem intervenção manual</span>
      </div>
    </div>
    <div class="step">
      <div class="step-n">04</div>
      <div class="step-c">
        <h3>Escreva instruções compostas</h3>
        <p>O poder real vem de combinar Skills e MCP numa instrução só. Em vez de executar cada etapa manualmente, descreva o fluxo completo: leitura de dados, processamento e entrega.</p>
        <span class="step-note">Exemplo: "Leia os emails não respondidos do Gmail sobre o projeto X, crie um resumo em Word e abra um card no Asana com as ações pendentes"</span>
      </div>
    </div>
    <div class="step">
      <div class="step-n">05</div>
      <div class="step-c">
        <h3>Refine por iteração</h3>
        <p>Na primeira tentativa, o resultado será bom. Na quinta iteração com ajustes progressivos, será excelente. Guarde os prompts que funcionaram bem — eles viram templates para uso recorrente.</p>
        <span class="step-note">Cada ajuste fino melhora todos os usos futuros</span>
      </div>
    </div>
  </div>
 
  <div style="margin-top:52px">
    <div class="s-lbl" style="margin-bottom:14px">Ferramentas com Suporte MCP</div>
    <table class="ttable">
      <thead><tr><th>Serviço</th><th>Categoria</th><th>O que o Claude pode fazer</th></tr></thead>
      <tbody>
        <tr><td class="tname">Gmail</td><td class="ttype">E-mail</td><td>Ler mensagens, buscar threads, criar rascunhos</td></tr>
        <tr><td class="tname">Slack</td><td class="ttype">Comunicação</td><td>Ler canais, enviar mensagens, criar canvas</td></tr>
        <tr><td class="tname">Notion</td><td class="ttype">Documentação</td><td>Criar e editar páginas e bancos de dados</td></tr>
        <tr><td class="tname">Asana</td><td class="ttype">Projetos</td><td>Criar tarefas, atualizar status, listar projetos</td></tr>
        <tr><td class="tname">Atlassian</td><td class="ttype">Projetos / Dev</td><td>Tickets Jira, páginas Confluence</td></tr>
        <tr><td class="tname">HubSpot</td><td class="ttype">CRM</td><td>Buscar contatos, negócios e atividades</td></tr>
        <tr><td class="tname">Linear</td><td class="ttype">Engenharia</td><td>Issues, projetos e ciclos de sprint</td></tr>
        <tr><td class="tname">Figma</td><td class="ttype">Design</td><td>Gerar diagramas, acessar componentes</td></tr>
      </tbody>
    </table>
  </div>
</div>
</section>
 
<!-- OPENSPEC -->
<section id="openspec" style="background:var(--paper2)">
<div class="sw reveal">
  <div class="s-lbl">04 — OpenSpec</div>
  <h2 class="s-title">OpenSpec e o padrão OpenAPI</h2>
  <p class="s-lead">OpenSpec é uma plataforma baseada no padrão OpenAPI — o formato universal para documentar, testar e compartilhar APIs. Entender isso amplia o que você consegue conectar ao Claude.</p>
 
  <div class="os-intro">
    <h3>O que é o OpenAPI?</h3>
    <p>OpenAPI (antigamente Swagger) é um <strong style="color:#fff">padrão aberto para descrever APIs REST</strong>. Em vez de escrever documentação em texto livre — que fica desatualizada e é difícil de usar programaticamente — você descreve sua API num arquivo estruturado (YAML ou JSON) que máquinas e humanos conseguem ler igualmente bem. O <a href="https://openspec.dev" target="_blank">openspec.dev</a> é uma plataforma que facilita criar, visualizar e compartilhar essas especificações sem precisar configurar ferramentas locais.</p>
  </div>
 
  <div class="analogy" style="margin-bottom:36px">
    <h4>Por que isso importa para seu trabalho com IA?</h4>
    <p>Quando o Claude usa MCP para se conectar ao Gmail ou ao Slack, ele faz chamadas de API por baixo dos panos. Cada servidor MCP tem uma especificação — uma lista do que ele pode fazer, quais parâmetros aceita, o que retorna. Quanto mais você entende esse contrato, mais consegue <strong>criar integrações customizadas</strong>, depurar problemas e expandir o que o Claude consegue fazer nos seus sistemas internos.</p>
  </div>
 
  <div class="s-lbl" style="margin-bottom:14px">Estrutura de uma especificação OpenAPI</div>
  <div class="codeblock">
    <div class="cblbl">Exemplo — openapi.yaml</div>
    <pre><span class="ck">openapi</span><span class="cp">:</span> <span class="cs">"3.1.0"</span>
<span class="ck">info</span><span class="cp">:</span>
  <span class="ck">title</span><span class="cp">:</span> <span class="cs">"API de Tarefas"</span>
  <span class="ck">version</span><span class="cp">:</span> <span class="cs">"1.0.0"</span>
 
<span class="ck">paths</span><span class="cp">:</span>
  <span class="ck">/tasks</span><span class="cp">:</span>
    <span class="ck">get</span><span class="cp">:</span>                        <span class="cc"># Lista todas as tarefas</span>
      <span class="ck">summary</span><span class="cp">:</span> <span class="cs">"Listar tarefas"</span>
      <span class="ck">responses</span><span class="cp">:</span>
        <span class="cs">"200"</span><span class="cp">:</span>
          <span class="ck">description</span><span class="cp">:</span> <span class="cs">"Lista retornada com sucesso"</span>
    <span class="ck">post</span><span class="cp">:</span>                       <span class="cc"># Cria uma nova tarefa</span>
      <span class="ck">summary</span><span class="cp">:</span> <span class="cs">"Criar tarefa"</span>
      <span class="ck">requestBody</span><span class="cp">:</span>
        <span class="ck">content</span><span class="cp">:</span>
          <span class="cs">"application/json"</span><span class="cp">:</span>
            <span class="ck">schema</span><span class="cp">:</span>
              <span class="ck">type</span><span class="cp">:</span> <span class="cs">"object"</span>
              <span class="ck">properties</span><span class="cp">:</span>
                <span class="ck">title</span><span class="cp">:</span>  <span class="cp">{</span> <span class="ck">type</span><span class="cp">:</span> <span class="cs">"string"</span> <span class="cp">}</span>
                <span class="ck">due</span><span class="cp">:</span>    <span class="cp">{</span> <span class="ck">type</span><span class="cp">:</span> <span class="cs">"string"</span><span class="cp">,</span> <span class="ck">format</span><span class="cp">:</span> <span class="cs">"date"</span> <span class="cp">}</span></pre>
  </div>
 
  <div class="os-cols">
    <div class="os-card">
      <h4>Métodos HTTP</h4>
      <p>Cada endpoint tem um método que descreve a intenção da operação.</p>
      <div style="margin-top:12px">
        <span class="method mget">GET</span> ler dados<br>
        <span class="method mpost">POST</span> criar<br>
        <span class="method mput">PUT</span> atualizar<br>
        <span class="method mdel">DELETE</span> excluir
      </div>
    </div>
    <div class="os-card">
      <h4>Schema de Dados</h4>
      <p>Cada endpoint define o formato exato dos dados que aceita e retorna — tipos, campos obrigatórios, exemplos e validações.</p>
    </div>
    <div class="os-card">
      <h4>Autenticação</h4>
      <p>A spec descreve como se autenticar — API Key, OAuth2, Bearer token — padronizando o acesso para todos os consumidores da API.</p>
    </div>
    <div class="os-card">
      <h4>Documentação Viva</h4>
      <p>A spec é a documentação. O OpenSpec e o Swagger UI geram interfaces interativas automaticamente a partir do arquivo YAML.</p>
    </div>
  </div>
 
  <div class="ftable" style="margin-top:0">
    <div class="frow">
      <div class="flabel">Como usar o OpenSpec<small>openspec.dev</small></div>
      <div class="ftext">Acesse <strong>openspec.dev</strong>, crie uma conta e importe ou escreva sua especificação OpenAPI. A plataforma valida o arquivo, gera documentação visual interativa e permite compartilhar com o time. Você pode testar endpoints diretamente na interface, sem precisar de Postman ou curl.</div>
    </div>
    <div class="frow">
      <div class="flabel">Conexão com MCP<small>Specs como contratos</small></div>
      <div class="ftext">Servidores MCP usam a mesma lógica de uma API REST documentada com OpenAPI. Quando você cria um servidor MCP customizado, documenta as ferramentas disponíveis com nomes, parâmetros e tipos — exatamente como um schema OpenAPI. O Claude usa esse contrato para saber o que pode chamar.</div>
    </div>
    <div class="frow">
      <div class="flabel">Claude + OpenSpec<small>Geração e análise</small></div>
      <div class="ftext">Você pode pedir ao Claude para gerar especificações OpenAPI a partir de uma descrição em linguagem natural, analisar uma spec existente, identificar endpoints faltando ou problemas de segurança — e exportar diretamente para o formato que o OpenSpec aceita.</div>
    </div>
  </div>
 
  <div class="codeblock" style="margin-top:36px">
    <div class="cblbl">Exemplo de instrução — Claude gerando uma spec OpenAPI</div>
    <pre><span class="cc">// Instrução para o Claude:</span>
 
<span class="cs">"Crie uma especificação OpenAPI 3.1 em YAML para uma API de
gerenciamento de projetos com os seguintes endpoints:
 
  GET  /projects          → listar projetos
  POST /projects          → criar projeto
  PUT  /projects/{id}     → atualizar projeto
  GET  /projects/{id}/tasks → listar tarefas do projeto
 
Use autenticação Bearer token, inclua schemas de request/response
completos e exemplos em cada endpoint."</span></pre>
  </div>
</div>
</section>
 
<!-- QUIZ -->
<section id="quiz">
<div class="sw reveal">
  <div class="s-lbl">05 — Quiz</div>
  <h2 class="s-title">Teste seu conhecimento</h2>
  <p class="s-lead">Cinco perguntas para verificar os conceitos essenciais.</p>
  <div class="qbox">
    <div class="qtrack" id="qtrack"></div>
    <div class="qq" id="qq"></div>
    <div class="qopts" id="qopts"></div>
    <div class="qfb" id="qfb"></div>
    <button class="qnext" id="qnext" onclick="nextQ()">Continuar</button>
  </div>
</div>
</section>
 
<footer>
  <div class="ft-brand">GUIA <span>·</span> Skills · MCP · OpenSpec</div>
  <p>Ative os conectores em claude.ai → Configurações → Conectores</p>
</footer>
 
<script>
window.addEventListener('scroll', () => {
  document.getElementById('pbar').style.width =
    (window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100) + '%';
});
 
function goTo(id) {
  document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
}
 
// ── THEME TOGGLE ──
function toggleTheme() {
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  const next = isDark ? 'light' : 'dark';
  document.documentElement.setAttribute('data-theme', next);
  document.getElementById('theme-lbl').textContent = isDark ? 'LIGHT' : 'DARK';
  try { localStorage.setItem('theme', next); } catch(e) {}
}
// Restore saved theme
(function() {
  try {
    const saved = localStorage.getItem('theme');
    if (saved === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
      document.addEventListener('DOMContentLoaded', () => {
        const lbl = document.getElementById('theme-lbl');
        if (lbl) lbl.textContent = 'DARK';
      });
    }
  } catch(e) {}
})();
 
const secIds = ['skills','mcp','connectivity','openspec','quiz'];
const navIds = { skills:'n-skills', mcp:'n-mcp', connectivity:'n-conn', openspec:'n-openspec', quiz:'n-quiz' };
window.addEventListener('scroll', () => {
  secIds.forEach(id => {
    const el = document.getElementById(id), nav = document.getElementById(navIds[id]);
    if (!el || !nav) return;
    const r = el.getBoundingClientRect();
    nav.classList.toggle('on', r.top <= 80 && r.bottom > 80);
  });
});
 
const obs = new IntersectionObserver(en => en.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); }), { threshold: 0.07 });
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
 
const qs = [
  { q: "O que diferencia uma Skill de uma instrução comum no chat?", opts: ["Skills são mensagens mais longas","Skills são arquivos de instruções especializados carregados automaticamente antes da execução de uma tarefa","Skills só funcionam com documentos","Skills exigem assinatura paga"], c: 1, fb: "Skills são arquivos estruturados no ambiente do sistema, consultados automaticamente pelo Claude. Você não repete as instruções — elas já estão disponíveis, selecionadas por contexto da tarefa." },
  { q: "O que o MCP resolve que o chat convencional não resolve?", opts: ["Respostas mais longas","Conexão com dados ao vivo e execução de ações em sistemas externos sem intermediação manual","Melhor formatação de texto","Memória de longo prazo"], c: 1, fb: "Correto. Com MCP, o Claude não apenas fala sobre seus dados — ele os acessa em tempo real e age diretamente nos seus sistemas: cria tarefas, envia mensagens, lê emails." },
  { q: "Qual a relação entre OpenAPI e servidores MCP?", opts: ["São tecnologias incompatíveis","Servidores MCP usam a mesma lógica de contratos: definem ferramentas com nomes, parâmetros e tipos, como um schema OpenAPI","OpenAPI substituiu o MCP","São a mesma coisa com nomes diferentes"], c: 1, fb: "Certo. Servidores MCP documentam suas ferramentas disponíveis com nomes, parâmetros e tipos retornados — exatamente como um schema OpenAPI. Entender um ajuda a entender o outro." },
  { q: "Para criar um relatório Word a partir de dados do Gmail usando o Claude, o que é necessário?", opts: ["Só o MCP do Gmail","Só a Skill de docx","Ambos: MCP para acessar os emails, Skill de docx para gerar o arquivo Word com qualidade profissional","Nenhum dos dois — o Claude faz isso por padrão"], c: 2, fb: "Exatamente. MCP traz os dados ao vivo do Gmail; a Skill garante que o Word gerado siga padrões profissionais. A combinação cobre o fluxo completo." },
  { q: "Qual o primeiro passo prático para integrar MCP ao seu trabalho?", opts: ["Aprender a programar servidores MCP","Acessar Configurações → Conectores no Claude.ai e ativar os serviços que você usa","Assinar um plano Enterprise","Criar uma conta no OpenSpec"], c: 1, fb: "Correto. O caminho mais direto é claude.ai → Configurações → Conectores. Em minutos você tem conexão ativa com Gmail, Slack, Notion e outros serviços do seu fluxo." }
];
 
let cur = 0, answered = false;
 
function renderQ() {
  const t = document.getElementById('qtrack');
  t.innerHTML = qs.map((_,i) => `<div class="qseg ${i < cur ? 'done' : i === cur ? 'cur' : ''}"></div>`).join('');
  const q = qs[cur];
  document.getElementById('qq').textContent = (cur + 1) + '. ' + q.q;
  document.getElementById('qfb').textContent = '';
  document.getElementById('qfb').classList.remove('show');
  document.getElementById('qnext').style.display = 'none';
  answered = false;
  const letters = ['A','B','C','D'];
  document.getElementById('qopts').innerHTML = q.opts.map((o, i) =>
    `<button class="qopt" onclick="ans(${i})"><span class="ql">${letters[i]}</span>${o}</button>`
  ).join('');
}
 
function ans(idx) {
  if (answered) return;
  answered = true;
  const q = qs[cur];
  document.querySelectorAll('.qopt').forEach((b, i) => {
    b.disabled = true;
    if (i === q.c) b.classList.add('ok');
    else if (i === idx && idx !== q.c) b.classList.add('err');
  });
  const fb = document.getElementById('qfb');
  fb.textContent = q.fb;
  fb.classList.add('show');
  const btn = document.getElementById('qnext');
  btn.style.display = 'block';
  btn.textContent = cur < qs.length - 1 ? 'Próxima pergunta' : 'Ver resultado';
}
 
function nextQ() {
  cur++;
  if (cur >= qs.length) {
    document.getElementById('qq').textContent = 'Guia concluído.';
    document.getElementById('qopts').innerHTML = '';
    const fb = document.getElementById('qfb');
    fb.textContent = 'Você tem a base completa para trabalhar com Skills, MCP e OpenSpec de forma profissional. Próximo passo: ative os conectores no Claude.ai e comece pelos fluxos mais repetitivos do seu trabalho.';
    fb.classList.add('show');
    document.getElementById('qnext').style.display = 'none';
    document.querySelectorAll('.qseg').forEach(s => { s.classList.add('done'); s.classList.remove('cur'); });
    return;
  }
  renderQ();
}
 
renderQ();
</script>
